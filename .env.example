# ──────────────────────────────────────────────────────────────────────────────
# Moodle Docker – Environment Variables
# Copy this file to .env and update values for your environment.
# ──────────────────────────────────────────────────────────────────────────────

# Database
MARIADB_DATABASE=moodle
MARIADB_USER=moodleuser
MARIADB_PASSWORD=moodlepass
MARIADB_ROOT_PASSWORD=rootpassword

# Moodle
# Local:      http://localhost:8090
# Production: https://online-lms.spims.site
MOODLE_WWWROOT=http://localhost:8090
# Set to true only if SSL is terminated by a reverse proxy (Nginx/Cloudflare)
MOODLE_SSLPROXY=false

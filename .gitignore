###############################################################################
# Moodle 4.4 – Docker Migration .gitignore
###############################################################################

# ── Secrets & local environment ───────────────────────────────────────────────
.env
# Keep the example file so others can bootstrap their own .env
!.env.example

# ── Moodle runtime / generated data (never in source control) ─────────────────
/moodledata/
/localcache/

# Moodle config is generated and contains DB credentials
# (keep config-dist.php, exclude the live one)
config.php
!config-dist.php

# ── Composer / PHP dependencies ───────────────────────────────────────────────
/vendor/

# ── Node / NPM (Grunt build tooling) ─────────────────────────────────────────
/node_modules/

# ── Build artefacts ───────────────────────────────────────────────────────────
# Compiled AMD/RequireJS modules (regenerated by grunt)
**/amd/build/
**/yui/build/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS & editor noise ────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# JetBrains IDEs
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.#*

# ── PHPUnit / Behat test artifacts ───────────────────────────────────────────
.phpunit.result.cache
/behat-results/

# ── Docker local overrides ────────────────────────────────────────────────────
docker-compose.override.yml
docker-compose.local.yml
